{
  "api": "POST /api/admin/account/delete",
  "cases": [
    {
      "name": "超级管理员删除自己返回 2295",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "POST",
      "path": "/api/admin/account/delete",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account_id": "10000000-0000-0000-0000-000000000001"
      },
      "expect_status": 200,
      "expect_business_status": 2295,
      "expect_field": {
        "status": 2295,
        "msg": "当前账号不能删除自己"
      }
    },
    {
      "name": "删除不存在账号返回 2294",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "POST",
      "path": "/api/admin/account/delete",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account_id": "10000000-0000-0000-0000-000000009999"
      },
      "expect_status": 200,
      "expect_business_status": 2294,
      "expect_field": {
        "status": 2294
      }
    },
    {
      "name": "超级管理员删除普通账号成功",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "POST",
      "path": "/api/admin/account/delete",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account_id": "10000000-0000-0000-0000-000000000005"
      },
      "expect_status": 200,
      "expect_business_status": 0,
      "expect_field": {
        "status": 0,
        "data": null
      },
      "side_effect_tables": [
        "account_accounts",
        "account_role_bindings"
      ]
    }
  ]
}
