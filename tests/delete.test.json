{
  "api": "POST /api/admin/account/delete",
  "cases": [
    {
      "name": "未登录删除账号返回 2291",
      "actor": "anonymous",
      "depends_on": [],
      "method": "POST",
      "path": "/api/admin/account/delete",
      "body": {
        "account_id": "10000000-0000-0000-0000-000000000002"
      },
      "expect_status": 200,
      "expect_business_status": 2291,
      "expect_field": {
        "status": 2291
      }
    },
    {
      "name": "超级管理员删除普通账号成功",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "POST",
      "path": "/api/admin/account/delete",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account_id": "10000000-0000-0000-0000-000000000005"
      },
      "expect_status": 200,
      "expect_business_status": 0,
      "expect_field": {
        "status": 0,
        "data": null
      },
      "side_effect_tables": [
        "account_accounts",
        "account_role_bindings"
      ]
    },
    {
