{
  "api": "POST /api/account/_validate-password",
  "cases": [
    {
      "name": "校验超级管理员密码成功",
      "actor": "anonymous",
      "depends_on": [],
      "method": "POST",
      "path": "/api/account/_validate-password",
      "body": {
        "account": "${range_tag}root",
        "password": "Root@123456"
      },
      "expect_status": 200,
      "expect_business_status": 0,
      "expect_field": {
        "status": 0,
        "data.account": "${range_tag}root",
        "data.is_super_admin": true
      }
    },
    {
      "name": "密码错误返回 2282",
      "actor": "anonymous",
      "depends_on": [],
      "method": "POST",
      "path": "/api/account/_validate-password",
      "body": {
        "account": "${range_tag}root",
        "password": "bad-password"
      },
      "expect_status": 200,
      "expect_business_status": 2282,
      "expect_field": {
        "status": 2282
      }
    }
  ]
}
