{
  "api": "POST /api/account/_create-temporary-admin",
  "cases": [
    {
      "name": "内部 token 有效时生成临时超管成功",
      "actor": "admin",
      "depends_on": [],
      "method": "POST",
      "path": "/api/account/_create-temporary-admin",
      "headers": {
        "X-Internal-Token": "${internal_token}"
      },
      "expect_status": 200,
      "expect_business_status": 0,
      "expect_field": {
        "status": 0,
        "data.ttl_seconds": 600
      },
      "side_effect_tables": [
        "account_accounts"
      ]
    },
    {
      "name": "缺失内部 token 返回未授权",
      "actor": "anonymous",
      "depends_on": [],
      "method": "POST",
      "path": "/api/account/_create-temporary-admin",
      "expect_status": 200,
      "expect_business_status": 2401,
      "expect_field": {
        "status": 2401
      },
      "expect_contains": "未授权访问内部接口"
    }
  ]
}
