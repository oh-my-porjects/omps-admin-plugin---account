{
  "api": "POST /api/account/create",
  "cases": [
    {
      "name": "未登录创建账号返回 2221",
      "actor": "anonymous",
      "depends_on": [],
      "method": "POST",
      "path": "/api/account/create",
      "body": {
        "account": "${range_tag}anonymous_${rand:8}",
        "password": "Passw0rd!",
        "status": "enabled",
        "role_ids": []
      },
      "expect_status": 200,
      "expect_business_status": 2221,
      "expect_field": {
        "status": 2221
      }
    },
    {
      "name": "超级管理员创建无角色启用账号成功",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "POST",
      "path": "/api/account/create",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account": "${range_tag}new_${rand:8}",
        "password": "Passw0rd!",
        "status": "enabled",
        "role_ids": []
      },
      "expect_status": 200,
      "expect_business_status": 0,
      "expect_field": {
        "status": 0,
        "data.account": "${range_tag}new_${rand:8}",
        "data.status": "enabled",
        "data.is_super_admin": false
      },
      "side_effect_tables": [
        "account_accounts",
        "account_role_bindings"
      ]
    },
    {
      "name": "账号重复返回 2224",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "POST",
      "path": "/api/account/create",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account": "${range_tag}root",
        "password": "Passw0rd!",
        "status": "enabled",
        "role_ids": []
      },
      "expect_status": 200,
      "expect_business_status": 2224,
      "expect_field": {
        "status": 2224
      }
    },
    {
      "name": "绑定不存在角色返回 2226",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "POST",
      "path": "/api/account/create",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account": "${range_tag}missing_role_${rand:8}",
        "password": "Passw0rd!",
        "status": "enabled",
        "role_ids": [
          "99999999-9999-4999-8999-999999999999"
        ]
      },
      "expect_status": 200,
      "expect_business_status": 2226,
      "expect_field": {
        "status": 2226
      }
    }
  ]
}
