{
  "api": "PUT /api/account/update",
  "cases": [
    {
      "name": "未登录更新账号返回 2251",
      "actor": "anonymous",
      "depends_on": [],
      "method": "PUT",
      "path": "/api/account/update",
      "body": {
        "account_id": "10000000-0000-0000-0000-000000000002",
        "status": "enabled",
        "role_ids": []
      },
      "expect_status": 200,
      "expect_business_status": 2251,
      "expect_field": {
        "status": 2251
      }
    },
    {
      "name": "超级管理员更新普通账号并清空角色成功",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "PUT",
      "path": "/api/account/update",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account_id": "10000000-0000-0000-0000-000000000002",
        "status": "enabled",
        "role_ids": []
      },
      "expect_status": 200,
      "expect_business_status": 0,
      "expect_field": {
        "status": 0,
        "data.account": "${range_tag}operator",
        "data.status": "enabled"
      },
      "side_effect_tables": [
        "account_accounts",
        "account_role_bindings"
      ]
    },
    {
      "name": "状态非法返回 2255",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "PUT",
      "path": "/api/account/update",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account_id": "10000000-0000-0000-0000-000000000002",
        "status": "archived",
        "role_ids": []
      },
      "expect_status": 200,
      "expect_business_status": 2255,
      "expect_field": {
        "status": 2255
      }
    },
    {
      "name": "账号 ID 非法返回 2253",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "PUT",
      "path": "/api/account/update",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account_id": "bad-id!",
        "status": "enabled",
        "role_ids": []
      },
      "expect_status": 200,
      "expect_business_status": 2253,
      "expect_field": {
        "status": 2253
      }
    },
    {
      "name": "无账号管理权限更新账号返回 2252",
      "actor": "user",
      "depends_on": [
        "login.1"
      ],
      "method": "PUT",
      "path": "/api/account/update",
      "body": {
        "operator_session_token": "${operator_session_token}",
        "account_id": "10000000-0000-0000-0000-000000000001",
        "status": "enabled",
        "role_ids": []
      },
      "expect_status": 200,
      "expect_business_status": 2252,
      "expect_field": {
        "status": 2252
      }
    },
    {
      "name": "绑定不存在角色返回 2256",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "PUT",
      "path": "/api/account/update",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account_id": "10000000-0000-0000-0000-000000000002",
        "status": "enabled",
        "role_ids": [
          "99999999-9999-4999-8999-999999999999"
        ]
      },
      "expect_status": 200,
      "expect_business_status": 2256,
      "expect_field": {
        "status": 2256
      }
    },
    {
      "name": "绑定禁用角色返回 2256",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "PUT",
      "path": "/api/account/update",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account_id": "10000000-0000-0000-0000-000000000002",
        "status": "enabled",
        "role_ids": [
          "00000000-0000-0000-0000-000000000005"
        ]
      },
      "expect_status": 200,
      "expect_business_status": 2256,
      "expect_field": {
        "status": 2256
      }
    }
  ]
}
