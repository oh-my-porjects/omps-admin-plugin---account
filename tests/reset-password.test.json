{
  "api": "PUT /api/account/reset-password",
  "cases": [
    {
      "name": "未登录重置账号密码返回 2261",
      "actor": "anonymous",
      "depends_on": [],
      "method": "PUT",
      "path": "/api/account/reset-password",
      "body": {
        "account_id": "10000000-0000-0000-0000-000000000002",
        "new_password": "New123"
      },
      "expect_status": 200,
      "expect_business_status": 2261,
      "expect_field": {
        "status": 2261
      }
    },
    {
      "name": "超级管理员重置普通账号密码成功",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "PUT",
      "path": "/api/account/reset-password",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account_id": "10000000-0000-0000-0000-000000000002",
        "new_password": "New123"
      },
      "expect_status": 200,
      "expect_business_status": 0,
      "expect_field": {
        "status": 0,
        "data.account_id": "10000000-0000-0000-0000-000000000002"
      },
      "expect_contains": "updated_at",
      "side_effect_tables": [
        "account_accounts"
      ]
    },
    {
      "name": "密码过短返回 2265",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "PUT",
      "path": "/api/account/reset-password",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account_id": "10000000-0000-0000-0000-000000000002",
        "new_password": "short"
      },
      "expect_status": 200,
      "expect_business_status": 2265,
      "expect_field": {
        "status": 2265
      }
    },
    {
      "name": "账号 ID 非法返回 2263",
      "actor": "admin",
      "depends_on": [
        "login.0"
      ],
      "method": "PUT",
      "path": "/api/account/reset-password",
      "body": {
        "operator_session_token": "${admin_session_token}",
        "account_id": "bad-id",
        "new_password": "New123"
      },
      "expect_status": 200,
      "expect_business_status": 2263,
      "expect_field": {
        "status": 2263
      }
    },
    {
      "name": "普通账号无账号管理权限返回 2262",
      "actor": "user",
      "depends_on": [
        "login.1"
      ],
      "method": "PUT",
      "path": "/api/account/reset-password",
      "body": {
        "operator_session_token": "${operator_session_token}",
        "account_id": "10000000-0000-0000-0000-000000000001",
        "new_password": "New123"
      },
      "expect_status": 200,
      "expect_business_status": 2262,
      "expect_field": {
        "status": 2262
      }
    }
  ]
}
