{
  "api": "PUT /api/admin-account/reset-password",
  "cases": [
    {
      "name": "未登录重置账号密码返回 2261",
      "actor": "anonymous",
      "depends_on": [],
      "method": "PUT",
      "path": "/api/admin-account/reset-password",
      "body": {"account_id": "${operator_account_id}", "new_password": "New123"},
      "expect_status": 200,
      "expect_business_status": 2261,
      "expect_field": {"status": 2261}
    },
    {
      "name": "超级管理员重置普通账号密码成功",
      "actor": "admin",
      "depends_on": [],
      "method": "PUT",
      "path": "/api/admin-account/reset-password",
      "body": {"operator_session_token": "${admin_session_token}", "account_id": "${operator_account_id}", "new_password": "New123"},
      "expect_status": 200,
      "expect_business_status": 0,
      "expect_field": {"status": 0, "data.account_id": "${operator_account_id}"},
      "expect_contains": "updated_at",
      "side_effect_tables": ["admin_accounts_accounts"]
    },
    {
      "name": "密码过短返回 2265",
      "actor": "admin",
      "depends_on": [],
      "method": "PUT",
      "path": "/api/admin-account/reset-password",
      "body": {"operator_session_token": "${admin_session_token}", "account_id": "${operator_account_id}", "new_password": "short"},
      "expect_status": 200,
      "expect_business_status": 2265,
      "expect_field": {"status": 2265}
    },
    {
      "name": "账号 ID 非法返回 2263",
      "actor": "admin",
      "depends_on": [],
      "method": "PUT",
      "path": "/api/admin-account/reset-password",
      "body": {"operator_session_token": "${admin_session_token}", "account_id": "bad-id", "new_password": "New123"},
      "expect_status": 200,
      "expect_business_status": 2263,
      "expect_field": {"status": 2263}
    },
    {
      "name": "普通账号无账号管理权限返回 2262",
      "actor": "admin",
      "depends_on": [],
      "method": "PUT",
      "path": "/api/admin-account/reset-password",
      "body": {"operator_session_token": "${operator_session_token}", "account_id": "${admin_account_id}", "new_password": "New123"},
      "expect_status": 200,
      "expect_business_status": 2262,
      "expect_field": {"status": 2262}
    }
  ]
}
