          {"name": "updated_at", "type": "string", "description": "更新时间，RFC3339"}
        ],
        "error_codes": [
          {"status": 2261, "msg": "请求体解析失败或未登录"},
          {"status": 2262, "msg": "无账号管理权限"},
          {"status": 2263, "msg": "account_id 参数非法"},
          {"status": 2264, "msg": "账号不存在"},
          {"status": 2265, "msg": "密码参数非法"},
          {"status": 2266, "msg": "普通后台账号不能重置超级管理员密码"},
          {"status": 2267, "msg": "重置密码失败或账号管理权限校验失败"}
        ]
      },
      "response_example": {"status": 0, "data": {"account_id": "00000000-0000-0000-0000-000000000002", "updated_at": "2026-05-10T10:25:00Z"}, "msg": "ok"},
      "rules": [
        {"category": "security", "title": "普通账号不能重置超级管理员密码", "body": "操作者不是超级管理员时，即使拥有账号管理权限，也不能重置超级管理员密码。", "code_loc": "account_handlers.go:247-259"}
      ]
    },
    {
      "method": "POST",
      "path": "/api/admin-account/check-permission",
      "endpoint_key": "POST /api/admin-account/check-permission",
      "title": "检查后台权限",
      "description": "检查会话账号是否拥有指定权限点，并返回命中的角色 ID。",
      "auth": "public",
      "params": [
        {"name": "session_token", "type": "string", "required": true, "constraint": "非空", "description": "登录会话令牌"},
        {"name": "permission_code", "type": "string", "required": true, "constraint": "正则 ^[a-z0-9._-]{3,80}$", "description": "权限码"}
      ],
      "request_example": {"session_token": "4f6e8b2a9c1d0e3f4a5b6c7d8e9f0011", "permission_code": "admin_account.manage"},
      "response": {
        "description": "返回是否允许、是否超级管理员及命中角色。",
        "data_type": "object",
        "fields": [
          {"name": "allowed", "type": "boolean", "description": "是否拥有权限"},
          {"name": "is_super_admin", "type": "boolean", "description": "是否超级管理员"},
          {"name": "matched_role_ids", "type": "array", "item_type": "string", "description": "命中权限的角色 ID 列表"}
        ],
        "error_codes": [
          {"status": 2271, "msg": "请求体解析失败或会话令牌参数非法"},
          {"status": 2272, "msg": "会话不存在或已过期"},
          {"status": 2273, "msg": "权限参数非法"},
          {"status": 2274, "msg": "账号不存在或已禁用"},
          {"status": 2275, "msg": "权限校验失败"}
        ]
      },
      "response_example": {"status": 0, "data": {"allowed": true, "is_super_admin": false, "matched_role_ids": ["00000000-0000-0000-0000-000000000003"]}, "msg": "ok"},
      "rules": [
        {"category": "security", "title": "超级管理员默认拥有权限", "body": "账号为超级管理员时不调用 admin_role 校验，直接返回 allowed=true，matched_role_ids 为空数组。", "code_loc": "account_handlers.go:300-308"}
      ]
    },
    {
      "method": "POST",
      "path": "/_internal/method-call/admin_account",
      "endpoint_key": "POST /_internal/method-call/admin_account",
